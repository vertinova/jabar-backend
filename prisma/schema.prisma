generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTH ====================
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  phone     String?
  avatar    String?
  pengcabId Int?
  forbasiId Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pengcab            Pengcab?             @relation(fields: [pengcabId], references: [id], onDelete: SetNull)
  rekomendasiEvents  RekomendasiEvent[]
  pendaftaranKejurda PendaftaranKejurda[]
  withdrawalRequests WithdrawalRequest[]

  @@map("users")
}

enum Role {
  ADMIN
  PENGCAB
  USER
  PENYELENGGARA
  UMUM
  // Super admin khusus pengelolaan e-voting (tidak di-SSO ke FORBASI Pusat,
  // tidak punya akses panel admin lain selain kelola vote).
  SUPERADMIN
}

// ==================== PENGCAB ====================
model Pengcab {
  id         Int         @id @default(autoincrement())
  forbasiId  Int?        @unique
  nama       String
  kota       String
  ketua      String      @default("Belum ditentukan")
  sekretaris String?
  bendahara  String?
  alamat     String?     @db.Text
  phone      String?
  email      String?
  logo       String?
  username   String?     @unique
  status     StatusAktif @default(AKTIF)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  users              User[]
  rekomendasiEvents  RekomendasiEvent[]
  pendaftaranKejurda PendaftaranKejurda[]
  kejurdaDiajukan    Kejurda[]

  @@map("pengcab")
}

enum StatusAktif {
  AKTIF
  NONAKTIF
}

// ==================== REKOMENDASI EVENT ====================
model RekomendasiEvent {
  id                Int            @id @default(autoincrement())
  namaEvent         String
  jenisEvent        String?
  tanggalMulai      DateTime?
  tanggalSelesai    DateTime?
  lokasi            String?
  deskripsi         String?        @db.Text
  penyelenggara     String?
  kontakPerson      String?
  noBilingSimpaskor String?
  dokumenSurat      String?
  persyaratan       Json? // Stores all persyaratan data (checkboxes, text, file paths)
  mataLomba         Json? // Stores mata lomba selections with individual schedules
  proposal          String? // File path for uploaded proposal kegiatan document
  poster            String? // File path for event poster/pamphlet
  status            StatusApproval @default(DRAFT)
  catatanPengcab    String?        @db.Text
  catatanAdmin      String?        @db.Text
  approvedPengcabAt DateTime?
  approvedPengdaAt  DateTime?
  nomorSurat        String? // Auto-generated: UM.001/FORBASI-JABAR/II/2026
  suratRekomendasi  String? // Path to generated surat rekomendasi PDF
  userId            Int
  pengcabId         Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  pengcab         Pengcab?           @relation(fields: [pengcabId], references: [id], onDelete: SetNull)
  votingConfig    EventVotingConfig?
  votingPurchases VotingPurchase[]
  rankingResults  RankingResult[]

  @@map("rekomendasi_events")
}

enum StatusApproval {
  DRAFT
  PENDING
  APPROVED_PENGCAB
  DISETUJUI
  DITOLAK
}

// ==================== E-VOTING ====================
enum VotingMode {
  TEAM
  PERSONAL
}

enum VotingPurchaseStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum VotingApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== RANKING PRESTASI ====================
model RankingResult {
  id                 Int              @id @default(autoincrement())
  rekomendasiEventId Int              @map("rekomendasi_event_id")
  event              RekomendasiEvent @relation(fields: [rekomendasiEventId], references: [id], onDelete: Cascade)
  participantName    String           @map("participant_name")
  participantKey     String           @map("participant_key")
  participantType    String           @default("TEAM") @map("participant_type")
  origin             String?
  category           String
  rank               Int
  title              String?
  points             Int
  notes              String?          @db.Text
  createdById        Int              @map("created_by_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([rekomendasiEventId])
  @@index([participantKey])
  @@index([points])
  @@map("ranking_results")
}

model EventVotingConfig {
  id                    Int                  @id @default(autoincrement())
  rekomendasiEventId    Int                  @unique @map("rekomendasi_event_id")
  enabled               Boolean              @default(false)
  isPaid                Boolean              @default(false) @map("is_paid")
  pricePerVote          Decimal              @default(0) @map("price_per_vote") @db.Decimal(12, 2)
  approvalStatus        VotingApprovalStatus @default(PENDING) @map("approval_status")
  organizerSharePercent Decimal              @default(0) @map("organizer_share_percent") @db.Decimal(5, 2)
  pengdaSharePercent    Decimal              @default(0) @map("pengda_share_percent") @db.Decimal(5, 2)
  developerSharePercent Decimal              @default(0) @map("developer_share_percent") @db.Decimal(5, 2)
  approvalNote          String?              @map("approval_note") @db.Text
  approvedAt            DateTime?            @map("approved_at")
  startDate             DateTime?            @map("start_date")
  endDate               DateTime?            @map("end_date")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  event      RekomendasiEvent @relation(fields: [rekomendasiEventId], references: [id], onDelete: Cascade)
  categories VotingCategory[]

  @@map("event_voting_configs")
}

model VotingCategory {
  id               Int               @id @default(autoincrement())
  configId         Int               @map("config_id")
  config           EventVotingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  title            String
  description      String?           @db.Text
  mode             VotingMode        @default(TEAM)
  position         String?
  maxVotesPerVoter Int               @default(1) @map("max_votes_per_voter")
  isActive         Boolean           @default(true) @map("is_active")
  order            Int               @default(0)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  nominees VotingNominee[]
  votes    VotingVote[]

  @@index([configId])
  @@map("voting_categories")
}

model VotingNominee {
  id              Int            @id @default(autoincrement())
  categoryId      Int            @map("category_id")
  category        VotingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nomineeName     String         @map("nominee_name")
  nomineePhoto    String?        @map("nominee_photo")
  nomineeSubtitle String?        @map("nominee_subtitle")
  voteCount       Int            @default(0) @map("vote_count")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  votes VotingVote[]

  @@index([categoryId])
  @@map("voting_nominees")
}

model VotingVote {
  id         Int             @id @default(autoincrement())
  categoryId Int             @map("category_id")
  category   VotingCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nomineeId  Int             @map("nominee_id")
  nominee    VotingNominee   @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  purchaseId Int?            @map("purchase_id")
  purchase   VotingPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  voterName  String?         @map("voter_name")
  voterEmail String?         @map("voter_email")
  voterIp    String?         @map("voter_ip")
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([categoryId])
  @@index([nomineeId])
  @@index([voterEmail, categoryId])
  @@map("voting_votes")
}

model VotingPurchase {
  id                    Int                  @id @default(autoincrement())
  rekomendasiEventId    Int                  @map("rekomendasi_event_id")
  event                 RekomendasiEvent     @relation(fields: [rekomendasiEventId], references: [id], onDelete: Cascade)
  buyerName             String               @map("buyer_name")
  buyerEmail            String               @map("buyer_email")
  buyerPhone            String?              @map("buyer_phone")
  supportMessage        String?              @map("support_message") @db.VarChar(200)
  categoryId            Int?                 @map("category_id")
  nomineeId             Int?                 @map("nominee_id")
  voteCount             Int                  @default(1) @map("vote_count")
  totalAmount           Decimal              @map("total_amount") @db.Decimal(12, 2)
  adminFee              Decimal              @default(0) @map("admin_fee") @db.Decimal(12, 2)
  qrisFee               Decimal              @default(0) @map("qris_fee") @db.Decimal(12, 2)
  grossAmount           Decimal?             @map("gross_amount") @db.Decimal(12, 2)
  purchaseCode          String               @unique @map("purchase_code")
  status                VotingPurchaseStatus @default(PENDING)
  midtransOrderId       String?              @unique @map("midtrans_order_id")
  snapToken             String?              @map("snap_token")
  paymentType           String?              @map("payment_type")
  paidAt                DateTime?            @map("paid_at")
  usedVotes             Int                  @default(0) @map("used_votes")
  organizerSharePercent Decimal              @default(0) @map("organizer_share_percent") @db.Decimal(5, 2)
  pengdaSharePercent    Decimal              @default(0) @map("pengda_share_percent") @db.Decimal(5, 2)
  organizerShareAmount  Decimal              @default(0) @map("organizer_share_amount") @db.Decimal(12, 2)
  pengdaShareAmount     Decimal              @default(0) @map("pengda_share_amount") @db.Decimal(12, 2)
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  votes VotingVote[]

  @@index([rekomendasiEventId])
  @@index([categoryId])
  @@index([nomineeId])
  @@index([buyerEmail])
  @@index([purchaseCode])
  @@map("voting_purchases")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// Who the withdrawal pays out. ORGANIZER = penyelenggara request flow (PENDING -> PAID).
// PENGDA / DEVELOPER = global pool payouts recorded directly by super admin (created PAID).
enum WithdrawalBeneficiary {
  ORGANIZER
  PENGDA
  DEVELOPER
}

model WithdrawalRequest {
  id            Int                   @id @default(autoincrement())
  userId        Int                   @map("user_id")
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  beneficiaryType WithdrawalBeneficiary @default(ORGANIZER) @map("beneficiary_type")
  amount        Decimal               @db.Decimal(12, 2)
  bankName      String                @map("bank_name")
  accountNumber String                @map("account_number")
  accountHolder String                @map("account_holder")
  note          String?               @db.Text
  status        WithdrawalStatus      @default(PENDING)
  adminNote     String?          @map("admin_note") @db.Text
  // Snapshot of the organizer's remaining balance (saldo akhir) at the moment
  // this withdrawal was marked PAID. Null until paid.
  balanceAfter  Decimal?         @map("balance_after") @db.Decimal(12, 2)
  processedById Int?             @map("processed_by_id")
  processedAt   DateTime?        @map("processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([beneficiaryType])
  @@map("withdrawal_requests")
}

// ==================== KEJURDA ====================

model KategoriEvent {
  id        Int      @id @default(autoincrement())
  kode      String   @unique // e.g. KEJURDA, LATGAB, TOT
  nama      String // Display name, editable
  warna     String   @default("green") // Tailwind color key
  grup      String   @default("kegiatan") // kompetisi | kegiatan
  urutan    Int      @default(0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kategori_event")
}

model Kejurda {
  id                Int           @id @default(autoincrement())
  namaKejurda       String
  jenisEvent        String        @default("KEJURDA") // KEJURDA, KEJURCAB, EVENT_REGULER
  targetPeserta     TargetPeserta @default(CLUB) // CLUB = via akun club, UMUM = via landing page
  tanggalMulai      DateTime
  tanggalSelesai    DateTime
  lokasi            String
  deskripsi         String?       @db.Text
  poster            String?
  statusBuka        Boolean       @default(true)
  earlyBirdAktif    Boolean       @default(true)
  pengcabId         Int?
  statusApproval    String        @default("DISETUJUI") // PENDING, DISETUJUI, DITOLAK
  catatanAdmin      String?       @db.Text
  biayaPendaftaran  Decimal?      @db.Decimal(12, 2)
  batasPendaftaran  DateTime?
  kontakPerson      String?
  kontakPhone       String?
  noBilingSimpaskor String?
  persyaratan       Json?
  mataLomba         Json?
  proposal          String?
  nomorSurat        String? // Auto-generated: UM.001/FORBASI-JABAR/II/2026
  suratRekomendasi  String? // Path to generated surat rekomendasi PDF
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  pendaftaran       PendaftaranKejurda[]
  persyaratanFields PersyaratanField[]
  pengcabPengaju    Pengcab?             @relation(fields: [pengcabId], references: [id], onDelete: SetNull)

  @@map("kejurda")
}

enum TargetPeserta {
  CLUB
  UMUM
}

// ==================== DYNAMIC FORM FIELDS ====================
model PersyaratanField {
  id         Int       @id @default(autoincrement())
  kejurdaId  Int
  label      String // Field label e.g., "Foto KTP", "Surat Keterangan Sehat"
  tipe       TipeField @default(TEXT)
  required   Boolean   @default(true)
  options    Json? // For SELECT/RADIO: ["Option 1", "Option 2"]
  keterangan String?   @db.Text // Helper text
  urutan     Int       @default(0)
  aktif      Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  kejurda Kejurda @relation(fields: [kejurdaId], references: [id], onDelete: Cascade)

  @@map("persyaratan_fields")
}

enum TipeField {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  RADIO
  CHECKBOX
  FILE_IMAGE
  FILE_PDF
  FILE_ANY
}

model PendaftaranKejurda {
  id              Int            @id @default(autoincrement())
  kejurdaId       Int
  userId          Int? // Nullable for UMUM registration without login
  pengcabId       Int?
  namaAtlet       String
  kategori        String
  kelasTanding    String?
  dokumen         String?
  dataPersyaratan Json? // Stores dynamic form submissions: { fieldId: value, ... }
  status          StatusApproval @default(PENDING)
  catatanAdmin    String?        @db.Text
  catatanPeserta  String?        @db.Text
  qrToken         String?        @unique
  // Guest fields for UMUM registration (when userId is null)
  guestEmail      String?
  guestPhone      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  kejurda Kejurda  @relation(fields: [kejurdaId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pengcab Pengcab? @relation(fields: [pengcabId], references: [id], onDelete: SetNull)

  @@map("pendaftaran_kejurda")
}

// ==================== LANDING PAGE CONFIG ====================
model HeroSlide {
  id        Int      @id @default(autoincrement())
  gambar    String // path to image file
  caption   String?
  urutan    Int      @default(0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_slides")
}

model Berita {
  id        Int      @id @default(autoincrement())
  judul     String
  ringkasan String?  @db.Text
  konten    String?  @db.LongText
  gambar    String?
  penulis   String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("berita")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String
  pesan     String   @db.Text
  dibaca    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("feedback")
}

model SiteConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

// ==================== FORMAT DOKUMEN (TEMPLATE DOWNLOAD) ====================
model FormatDokumen {
  id        Int      @id @default(autoincrement())
  nama      String // Display name e.g. "Pakta Integritas"
  deskripsi String? // Short description
  filePath  String // Path to the file in uploads/
  kategori  String   @default("umum") // umum, administratif, perangkat, etc.
  urutan    Int      @default(0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("format_dokumen")
}

model StrukturOrganisasi {
  id        Int      @id @default(autoincrement())
  jabatan   String // e.g., "Ketua Umum", "Sekretaris", "Bendahara", "Seksi Humas"
  nama      String
  foto      String? // path to photo
  urutan    Int      @default(0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("struktur_organisasi")
}

// ==================== MERCHANDISE ====================
model Merchandise {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?  @db.Text
  harga     Decimal? @db.Decimal(12, 2)
  gambar    String?
  link      String? // External purchase link
  urutan    Int      @default(0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("merchandise")
}

// ==================== API KEYS (Remote Access) ====================
model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String // e.g. "FORBASI Pusat"
  keyHash     String    @unique // SHA-256 hash of the actual key
  keyPrefix   String // First 8 chars for display: "sk_ab12..."
  permissions Json // JSON array: ["landing:read","landing:write","landing:delete"]
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs ApiKeyLog[]

  @@map("api_keys")
}

model ApiKeyLog {
  id         Int      @id @default(autoincrement())
  apiKeyId   Int
  endpoint   String
  method     String
  ip         String?
  userAgent  String?  @db.Text
  statusCode Int?
  createdAt  DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@map("api_key_logs")
}
